# ─── Database (PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/db

# ─── Auth.js ─────────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET=your-secret-here
# URL da aplicacao (http://localhost:3000 para dev)
AUTH_URL=http://localhost:3000

# ─── Google OAuth (Social Login) ────────────────────────────────────
# 1. Ir a https://console.cloud.google.com/apis/credentials
# 2. Criar "OAuth 2.0 Client ID" (tipo: Web application)
# 3. Autorizar redirect URI: ${AUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_AUTH_ENABLED=true

# ─── Resend (Emails) ────────────────────────────────────────────────
# Em dev (NODE_ENV=development), emails sao logados no console automaticamente.
# Para enviar emails reais:
# 1. Criar conta em https://resend.com
# 2. Gerar API Key em https://resend.com/api-keys
# 3. Verificar dominio ou usar onboarding@resend.dev (solo envia para o dono da API key)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL="onboarding@resend.dev"

# ─── Vercel Blob (File Uploads) ─────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# ─── WebSocket Server ───────────────────────────────────────────────
# URL publica para o frontend conectar (browser)
# Em dev: NEXT_PUBLIC_WS_URL=ws://localhost:3001
# Em producao: NEXT_PUBLIC_WS_URL=wss://seu-vps:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# URL para o servidor Next.js conectar ao WS (server-side)
# Em dev: WS_SERVER_URL=ws://localhost:3001
# Em producao: WS_SERVER_URL=ws://seu-vps:3001
WS_SERVER_URL=ws://localhost:3001
