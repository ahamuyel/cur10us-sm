generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model School {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  nif               String?
  email             String                 @unique
  phone             String
  address           String
  city              String
  provincia         String
  logo              String?
  primaryColor      String?
  secondaryColor    String?
  slogan            String?
  contactEmail      String?
  socialFacebook    String?
  socialInstagram   String?
  socialWhatsapp    String?
  loginMessage      String?
  footerText        String?
  features          Json?
  status            SchoolStatus           @default(pendente)
  rejectReason      String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  academicHistories AcademicHistory[]
  academicYears     AcademicYear[]
  adminPermissions  AdminPermission[]
  announcements     Announcement[]
  applications      Application[]
  assignments       Assignment[]
  submissions       AssignmentSubmission[]
  attendances       Attendance[]
  classes           Class[]
  courses           Course[]
  cycleCertificates CycleCertificate[]
  enrollments       Enrollment[]
  exams             Exam[]
  gradingConfigs    GradingConfig[]
  importJobs        ImportJob[]
  lessons           Lesson[]
  messages          Message[]
  notifications     Notification[]
  parents           Parent[]
  results           Result[]
  schoolClasses     SchoolClass[]
  schoolCourses     SchoolCourse[]
  schoolSubjects    SchoolSubject[]
  students          Student[]
  subjects          Subject[]
  supportTickets    SupportTicket[]
  teachers          Teacher[]
  users             User[]
}

model Application {
  id              String            @id @default(cuid())
  name            String
  email           String
  phone           String
  role            Role
  message         String?
  status          ApplicationStatus @default(pendente)
  rejectReason    String?
  trackingToken   String            @unique @default(cuid())
  schoolId        String
  userId          String?           @unique
  gender          Gender?
  documentType    String?
  documentNumber  String?
  dateOfBirth     DateTime?
  desiredGrade    Int?
  desiredCourseId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  school          School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User?             @relation(fields: [userId], references: [id])
}

model User {
  id                     String                  @id @default(cuid())
  name                   String
  email                  String                  @unique
  hashedPassword         String?
  role                   Role                    @default(student)
  image                  String?
  isActive               Boolean                 @default(false)
  provider               String?
  providerId             String?
  mustChangePassword     Boolean                 @default(false)
  profileComplete        Boolean                 @default(true)
  sessionVersion         Int                     @default(0)
  emailVerified          Boolean                 @default(false)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean                 @default(false)
  twoFactorVerifiedAt    DateTime?
  schoolId               String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  adminPermission        AdminPermission?
  authoredAnnouncements  Announcement[]          @relation("AuthoredAnnouncements")
  targetedAnnouncements  Announcement[]          @relation("TargetedAnnouncements")
  announcementReads      AnnouncementRead[]
  application            Application?
  dashboardPreference    DashboardPreference?
  emailVerificationToken EmailVerificationToken?
  friendOf               Friend[]                @relation("FriendOf")
  friends                Friend[]                @relation("UserFriends")
  importJobs             ImportJob[]             @relation("UserImports")
  sentMessages           Message[]               @relation("SentMessages")
  receivedMessages       Message[]               @relation("ReceivedMessages")
  notifications          Notification[]
  parent                 Parent?
  passwordResetTokens    PasswordResetToken[]
  student                Student?
  supportTickets         SupportTicket[]         @relation("UserTickets")
  supportMessages        SupportTicketMessage[]  @relation("UserTicketMessages")
  teacher                Teacher?
  school                 School?                 @relation(fields: [schoolId], references: [id])
  userPreference         UserPreference?
  conversationsAsParticipant1 Conversation[]     @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[]     @relation("ConversationParticipant2")
  chatMessages           ChatMessage[]

}

model PasswordResetToken {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerificationToken {
  id      String   @id @default(cuid())
  token   String   @unique
  expires DateTime
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Teacher {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  phone           String?
  address         String?
  foto            String?
  userId          String?          @unique
  schoolId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  assignments     Assignment[]
  exams           Exam[]
  lessons         Lesson[]
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User?            @relation(fields: [userId], references: [id])
  teacherClasses  TeacherClass[]
  teacherSubjects TeacherSubject[]
}

model Student {
  id                String                 @id @default(cuid())
  name              String
  email             String                 @unique
  phone             String?
  address           String?
  foto              String?
  gender            Gender?
  dateOfBirth       DateTime?
  documentType      String?
  documentNumber    String?
  classId           String?
  userId            String?                @unique
  schoolId          String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  academicHistories AcademicHistory[]
  submissions       AssignmentSubmission[]
  attendances       Attendance[]
  cycleCertificates CycleCertificate[]
  enrollments       Enrollment[]
  results           Result[]
  class             Class?                 @relation(fields: [classId], references: [id])
  school            School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User?                  @relation(fields: [userId], references: [id])
  parents           Parent[]               @relation("ParentStudents")
}

model Parent {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  phone     String?
  address   String?
  foto      String?
  userId    String?   @unique
  schoolId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])
  students  Student[] @relation("ParentStudents")
}

model Subject {
  id              String           @id @default(cuid())
  name            String
  globalSubjectId String?
  schoolId        String
  assignments     Assignment[]
  courseSubjects  CourseSubject[]
  exams           Exam[]
  lessons         Lesson[]
  results         Result[]
  globalSubject   GlobalSubject?   @relation(fields: [globalSubjectId], references: [id])
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherSubjects TeacherSubject[]

  @@unique([name, schoolId])
}

model Course {
  id             String          @id @default(cuid())
  name           String
  globalCourseId String?
  schoolId       String
  announcements  Announcement[]
  classes        Class[]
  globalCourse   GlobalCourse?   @relation(fields: [globalCourseId], references: [id])
  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  courseSubjects CourseSubject[]
  gradingConfigs GradingConfig[]

  @@unique([name, schoolId])
}

model CourseSubject {
  id        String  @id @default(cuid())
  courseId  String
  subjectId String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([courseId, subjectId])
}

model Class {
  id             String         @id @default(cuid())
  name           String
  grade          Int
  capacity       Int
  period         ClassPeriod    @default(regular)
  courseId       String?
  globalClassId  String?
  academicYearId String?
  supervisorId   String?
  schoolId       String
  announcements  Announcement[]
  assignments    Assignment[]
  attendances    Attendance[]
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  course         Course?        @relation(fields: [courseId], references: [id])
  globalClass    GlobalClass?   @relation(fields: [globalClassId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
  exams          Exam[]
  lessons        Lesson[]
  students       Student[]
  teacherClasses TeacherClass[]

  @@unique([name, schoolId])
}

model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model TeacherClass {
  id        String  @id @default(cuid())
  teacherId String
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId])
}

model Lesson {
  id             String        @id @default(cuid())
  day            String
  startTime      String
  endTime        String
  room           String?
  materials      Json?
  subjectId      String
  classId        String
  teacherId      String
  academicYearId String?
  schoolId       String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  attendances    Attendance[]
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher        Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Exam {
  id             String        @id @default(cuid())
  title          String?
  date           DateTime
  subjectId      String
  classId        String
  teacherId      String
  academicYearId String?
  schoolId       String
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
  class          Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher        Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  results        Result[]
}

model Assignment {
  id             String                 @id @default(cuid())
  title          String
  description    String?
  dueDate        DateTime
  maxScore       Float                  @default(20)
  subjectId      String
  classId        String
  teacherId      String
  academicYearId String?
  schoolId       String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt
  academicYear   AcademicYear?          @relation(fields: [academicYearId], references: [id])
  class          Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject        Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher        Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions    AssignmentSubmission[]
  results        Result[]
}

model Result {
  id              String        @id @default(cuid())
  score           Float
  type            String
  date            DateTime
  trimester       Trimester?
  academicYear    String?
  academicYearId  String?
  studentId       String
  subjectId       String
  examId          String?
  assignmentId    String?
  schoolId        String

  @@unique([studentId, subjectId, trimester, academicYearId])
  academicYearRef AcademicYear? @relation(fields: [academicYearId], references: [id])
  assignment      Assignment?   @relation(fields: [assignmentId], references: [id])
  exam            Exam?         @relation(fields: [examId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject         Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Attendance {
  id             String           @id @default(cuid())
  date           DateTime
  status         AttendanceStatus
  studentId      String
  classId        String
  lessonId       String?
  academicYearId String?
  schoolId       String
  academicYear   AcademicYear?    @relation(fields: [academicYearId], references: [id])
  class          Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  lesson         Lesson?          @relation(fields: [lessonId], references: [id])
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, classId, lessonId])
}

model Message {
  id        String   @id @default(cuid())
  subject   String
  body      String
  fromId    String
  toId      String?
  toAll     Boolean  @default(false)
  read      Boolean  @default(false)
  schoolId  String
  createdAt DateTime @default(now())
  from      User     @relation("SentMessages", fields: [fromId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  to        User?    @relation("ReceivedMessages", fields: [toId], references: [id])
}

model Conversation {
  id              String   @id @default(cuid())
  participant1Id  String
  participant2Id  String
  lastMessageAt   DateTime?
  createdAt       DateTime @default(now())
  participant1    User     @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2    User     @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages        ChatMessage[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
}

model ChatMessage {
  id              String       @id @default(cuid())
  conversationId  String
  senderId        String
  text            String
  readAt          DateTime?
  createdAt       DateTime     @default(now())
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Announcement {
  id           String               @id @default(cuid())
  title        String
  description  String
  priority     AnnouncementPriority @default(informativo)
  classId      String?
  courseId     String?
  authorId     String?
  targetUserId String?
  scheduledAt  DateTime?
  publishedAt  DateTime?
  schoolId     String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  author       User?                @relation("AuthoredAnnouncements", fields: [authorId], references: [id])
  class        Class?               @relation(fields: [classId], references: [id])
  course       Course?              @relation(fields: [courseId], references: [id])
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  targetUser   User?                @relation("TargetedAnnouncements", fields: [targetUserId], references: [id])
  reads        AnnouncementRead[]
}

model PlatformConfig {
  id                String   @id @default("singleton")
  name              String   @default("Cur10usX")
  logo              String?
  contactEmail      String?
  contactPhone      String?
  description       String?
  maintenanceMode   Boolean  @default(false)
  allowRegistration Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GlobalSubject {
  id             String          @id @default(cuid())
  name           String          @unique
  code           String          @unique
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  schoolSubjects SchoolSubject[]
  subjects       Subject[]
}

model GlobalCourse {
  id            String         @id @default(cuid())
  name          String         @unique
  code          String         @unique
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  courses       Course[]
  schoolCourses SchoolCourse[]
}

model GlobalClass {
  id            String          @id @default(cuid())
  name          String          @unique
  grade         Int             @unique
  cycleId       String?
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  classes       Class[]
  cycle         EducationCycle? @relation(fields: [cycleId], references: [id])
  schoolClasses SchoolClass[]
}

model SchoolSubject {
  id              String        @id @default(cuid())
  globalSubjectId String
  schoolId        String
  localName       String?
  active          Boolean       @default(true)
  globalSubject   GlobalSubject @relation(fields: [globalSubjectId], references: [id])
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([globalSubjectId, schoolId])
}

model SchoolCourse {
  id             String       @id @default(cuid())
  globalCourseId String
  schoolId       String
  localName      String?
  active         Boolean      @default(true)
  globalCourse   GlobalCourse @relation(fields: [globalCourseId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([globalCourseId, schoolId])
}

model SchoolClass {
  id            String      @id @default(cuid())
  globalClassId String
  schoolId      String
  localName     String?
  active        Boolean     @default(true)
  globalClass   GlobalClass @relation(fields: [globalClassId], references: [id])
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([globalClassId, schoolId])
}

model AcademicYear {
  id                String             @id @default(cuid())
  name              String
  startDate         DateTime
  endDate           DateTime
  isCurrent         Boolean            @default(false)
  status            AcademicYearStatus @default(aberto)
  schoolId          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  academicHistories AcademicHistory[]
  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments       Assignment[]
  attendances       Attendance[]
  classes           Class[]
  cycleCertificates CycleCertificate[]
  enrollments       Enrollment[]
  exams             Exam[]
  gradingConfigs    GradingConfig[]
  lessons           Lesson[]
  results           Result[]

  @@unique([name, schoolId])
}

model GlobalGradingConfig {
  id                String          @id @default(cuid())
  classGrade        Int?
  courseId          String?
  trimesterWeights  Json?
  passingGrade      Float           @default(10)
  resourceMinGrade  Float?
  maxFailedSubjects Int             @default(2)
  trimesterFormula  Json?
  finalFormula      Json?
  directFailGrade   Float?
  roundingMode      RoundingMode    @default(arredondar)
  roundingScale     Int             @default(1)
  recursoAllowed    Boolean         @default(true)
  active            Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  schoolConfigs     GradingConfig[]

  @@unique([classGrade, courseId])
}

model GradingConfig {
  id                    String               @id @default(cuid())
  schoolId              String
  academicYearId        String?
  globalGradingConfigId String?
  overrides             Json?
  classGrade            Int?
  courseId              String?
  trimesterWeights      Json?
  passingGrade          Float                @default(10)
  resourceMinGrade      Float?
  maxFailedSubjects     Int                  @default(2)
  trimesterFormula      Json?
  finalFormula          Json?
  directFailGrade       Float?
  roundingMode          RoundingMode         @default(arredondar)
  roundingScale         Int                  @default(1)
  recursoAllowed        Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  academicYear          AcademicYear?        @relation(fields: [academicYearId], references: [id])
  course                Course?              @relation(fields: [courseId], references: [id])
  globalGradingConfig   GlobalGradingConfig? @relation(fields: [globalGradingConfigId], references: [id])
  school                School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId, classGrade, courseId])
}

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  classId        String
  academicYearId String
  schoolId       String
  status         EnrollmentStatus @default(ativa)
  finalAverage   Float?
  failedSubjects Int?
  observation    String?
  decidedAt      DateTime?
  enrolledAt     DateTime         @default(now())
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
}

model AdminPermission {
  id                     String     @id @default(cuid())
  userId                 String     @unique
  level                  AdminLevel
  schoolId               String
  canManageApplications  Boolean    @default(false)
  canManageTeachers      Boolean    @default(false)
  canManageStudents      Boolean    @default(false)
  canManageParents       Boolean    @default(false)
  canManageClasses       Boolean    @default(false)
  canManageCourses       Boolean    @default(false)
  canManageSubjects      Boolean    @default(false)
  canManageLessons       Boolean    @default(false)
  canManageExams         Boolean    @default(false)
  canManageAssignments   Boolean    @default(false)
  canManageResults       Boolean    @default(false)
  canManageAttendance    Boolean    @default(false)
  canManageMessages      Boolean    @default(false)
  canManageAnnouncements Boolean    @default(false)
  canManageAdmins        Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  school                 School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  link      String?
  type      String
  read      Boolean  @default(false)
  schoolId  String
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AssignmentSubmission {
  id            String           @id @default(cuid())
  assignmentId  String
  studentId     String
  content       String?
  attachmentUrl String?
  status        AssignmentStatus @default(pendente)
  score         Float?
  feedback      String?
  submittedAt   DateTime?
  evaluatedAt   DateTime?
  schoolId      String
  assignment    Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  school        School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
}

model DashboardPreference {
  id        String   @id @default(cuid())
  userId    String   @unique
  layout    Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  theme          String   @default("light")
  locale         String   @default("pt")
  notifyPlatform Boolean  @default(true)
  notifyEmail    Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id          String                 @id @default(cuid())
  subject     String
  description String
  priority    TicketPriority         @default(media)
  status      TicketStatus           @default(aberto)
  attachment  String?
  userId      String
  schoolId    String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  school      School?                @relation(fields: [schoolId], references: [id])
  user        User                   @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportTicketMessage[]
}

model SupportTicketMessage {
  id        String        @id @default(cuid())
  content   String
  isStaff   Boolean       @default(false)
  userId    String
  ticketId  String
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User          @relation("UserTicketMessages", fields: [userId], references: [id], onDelete: Cascade)
}

model ImportJob {
  id           String       @id @default(cuid())
  filename     String
  userType     Role
  status       ImportStatus @default(pendente)
  totalRows    Int          @default(0)
  successCount Int          @default(0)
  failedCount  Int          @default(0)
  errors       Json?
  report       Json?
  importedById String
  schoolId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  importedBy   User         @relation("UserImports", fields: [importedById], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model EducationCycle {
  id            String         @id @default(cuid())
  name          String         @unique
  level         EducationLevel
  startGrade    Int
  endGrade      Int
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  globalClasses GlobalClass[]
}

model AcademicHistory {
  id             String           @id @default(cuid())
  studentId      String
  academicYearId String
  schoolId       String
  grade          Int
  courseName     String?
  className      String
  finalAverage   Float?
  status         EnrollmentStatus
  failedSubjects Int?
  observation    String?
  subjectResults Json
  decidedAt      DateTime?
  createdAt      DateTime         @default(now())
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school         School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId, schoolId])
}

model CycleCertificate {
  id              String         @id @default(cuid())
  studentId       String
  schoolId        String
  cycleLevel      EducationLevel
  cycleName       String
  completionGrade Int
  finalAverage    Float
  completionDate  DateTime
  academicYearId  String
  certificateData Json
  createdAt       DateTime       @default(now())
  academicYear    AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school          School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, cycleLevel, schoolId])
}

model Friend {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  friend    User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  userRole    String
  action      String
  entity      String
  entityId    String?
  schoolId    String?
  description String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([entity, entityId])
  @@index([createdAt])
}

enum Role {
  super_admin
  school_admin
  teacher
  student
  parent
}

enum SchoolStatus {
  pendente
  aprovada
  ativa
  suspensa
  rejeitada
}

enum ApplicationStatus {
  pendente
  em_analise
  aprovada
  matriculada
  rejeitada
}

enum AttendanceStatus {
  presente
  ausente
  atrasado
}

enum AdminLevel {
  primary
  secondary
}

enum AnnouncementPriority {
  informativo
  importante
  urgente
}

enum AssignmentStatus {
  pendente
  entregue
  avaliada
  atrasada
}

enum Trimester {
  primeiro
  segundo
  terceiro
}

enum Gender {
  masculino
  feminino
}

enum TicketStatus {
  aberto
  em_andamento
  resolvido
  arquivado
}

enum TicketPriority {
  baixa
  media
  alta
  urgente
}

enum ImportStatus {
  pendente
  processando
  concluida
  parcial
  falhada
}

enum ClassPeriod {
  regular
  pos_laboral
}

enum AcademicYearStatus {
  aberto
  em_encerramento
  encerrado
}

enum EducationLevel {
  primario
  primeiro_ciclo
  segundo_ciclo
}

enum RoundingMode {
  truncar
  arredondar
  teto
}

enum EnrollmentStatus {
  ativa
  transferida
  cancelada
  concluida
  aprovada
  reprovada
  em_recurso
}
