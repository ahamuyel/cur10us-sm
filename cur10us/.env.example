# ─── Database (Neon PostgreSQL) ───────────────────────────────────
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ─── Auth.js ─────────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
AUTH_SECRET=""
# URL da aplicacao (producao: https://seudominio.com)
AUTH_URL="http://localhost:3000"

# ─── Google OAuth (Social Login) ─────────────────────────────────
# 1. Ir a https://console.cloud.google.com/apis/credentials
# 2. Criar "OAuth 2.0 Client ID" (tipo: Web application)
# 3. Authorized redirect URIs: https://seudominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_AUTH_ENABLED="true"

# ─── Resend (Emails de recuperacao de password) ──────────────────
# 1. Criar conta em https://resend.com
# 2. Gerar API Key em https://resend.com/api-keys
# 3. Verificar dominio ou usar onboarding@resend.dev para testes
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"
